import http
import lib as http_router
import logging
import testing


class _ResponseCapture(object):
    def __init__(self, on_done: ?proc(_ResponseCapture) -> None = None):
        self.status = 0
        self.headers = {}
        self.body = ""
        self.on_done = on_done

    def respond(self, status: int, headers: dict[str, str], body: str):
        self.status = status
        self.headers = headers
        self.body = body
        on_done = self.on_done
        if on_done is not None:
            on_done(self)


def _request(method: str, path: str, headers: dict[str, str] = {}, body: bytes = b"") -> http.Request:
    return http.Request(method, path, b"1.1", headers, body)


def _ok_handler(ctx: http_router.Context, respond: proc(int, dict[str, str], str) -> None):
    respond(200, {"Content-Type": "text/plain"}, "ok")


def _suffix_middleware(suffix: str) -> proc(proc(http_router.Context, proc(int, dict[str, str], str) -> None) -> None) -> proc(http_router.Context, proc(int, dict[str, str], str) -> None) -> None:
    def middleware(downstream_handler: proc(http_router.Context, proc(int, dict[str, str], str) -> None) -> None):
        def wrapped(ctx: http_router.Context, respond: proc(int, dict[str, str], str) -> None):
            def wrapped_respond(status: int, headers: dict[str, str], body: str):
                respond(status, headers, "{body}{suffix}")

            downstream_handler(ctx, wrapped_respond)
        return wrapped
    return middleware


def _serve_and_assert(t: testing.EnvT, r, request, expected_status, expected_body, next=None):
    def done(res: _ResponseCapture):
        try:
            testing.assertEqual(res.status, expected_status)
            testing.assertEqual(res.body, expected_body)
            if next is not None:
                next()
            else:
                t.success()
        except Exception as e:
            t.failure(e)

    try:
        res = _ResponseCapture(done)
        r.serve(request, res.respond)
    except Exception as e:
        t.failure(e)


actor _test_route_precedence_and_params(t: testing.EnvT):
    r = http_router.Router()

    def static_handler(ctx: http_router.Context, respond: proc(int, dict[str, str], str) -> None):
        respond(200, {"Content-Type": "text/plain"}, "static")

    def param_handler(ctx: http_router.Context, respond: proc(int, dict[str, str], str) -> None):
        respond(200, {"Content-Type": "text/plain"}, "param:{ctx.param("id")}")

    def wildcard_handler(ctx: http_router.Context, respond: proc(int, dict[str, str], str) -> None):
        respond(200, {"Content-Type": "text/plain"}, "wild:{ctx.param("tail")}")

    r.get("/items/{{id}}", param_handler)
    r.get("/items/special", static_handler)
    r.get("/items/*tail", wildcard_handler)

    def after_static():
        _serve_and_assert(t, r, _request("GET", "/items/123?x=1"), 200, "param:123", after_param)

    def after_param():
        _serve_and_assert(t, r, _request("GET", "/items/a/b/c"), 200, "wild:a/b/c")

    try:
        _serve_and_assert(t, r, _request("GET", "/items/special"), 200, "static", after_static)
    except Exception as e:
        t.failure(e)


actor _test_backtracks_when_static_path_has_wrong_method(t: testing.EnvT):
    r = http_router.Router()

    def post_static_handler(ctx: http_router.Context, respond: proc(int, dict[str, str], str) -> None):
        respond(201, {"Content-Type": "text/plain"}, "created")

    def param_get_handler(ctx: http_router.Context, respond: proc(int, dict[str, str], str) -> None):
        respond(200, {"Content-Type": "text/plain"}, "param:{ctx.param("id")}")

    def wildcard_get_handler(ctx: http_router.Context, respond: proc(int, dict[str, str], str) -> None):
        respond(200, {"Content-Type": "text/plain"}, "wild:{ctx.param("tail")}")

    r.post("/items/special", post_static_handler)
    r.get("/items/{{id}}", param_get_handler)
    r.get("/files/*tail", wildcard_get_handler)
    r.post("/files/readme", post_static_handler)

    def after_param():
        _serve_and_assert(t, r, _request("GET", "/files/readme"), 200, "wild:readme")

    try:
        _serve_and_assert(t, r, _request("GET", "/items/special"), 200, "param:special", after_param)
    except Exception as e:
        t.failure(e)


actor _test_query_param_helper(t: testing.EnvT):
    r = http_router.Router()

    def query_handler(ctx: http_router.Context, respond: proc(int, dict[str, str], str) -> None):
        respond(200, {"Content-Type": "text/plain"}, "{ctx.query_param("q", "<missing>")}|{ctx.query_param("empty", "<missing>")}|{ctx.query_param("missing", "<missing>")}")

    r.get("/search", query_handler)

    try:
        _serve_and_assert(t, r, _request("GET", "/search?q=abc&empty"), 200, "abc||<missing>")
    except Exception as e:
        t.failure(e)


actor _test_context_values_can_be_set_in_middleware(t: testing.EnvT):
    r = http_router.Router()

    def inject_values(next_handler: proc(http_router.Context, proc(int, dict[str, str], str) -> None) -> None):
        def wrapped(ctx: http_router.Context, respond: proc(int, dict[str, str], str) -> None):
            route_id = ctx.param("id")
            ctx.set("device_name", "edge-1")
            ctx.set("device_index", 7)
            ctx.set("route_id_seen_by_middleware", route_id)
            next_handler(ctx, respond)
        return wrapped

    def handler(ctx: http_router.Context, respond: proc(int, dict[str, str], str) -> None):
        device_name = ctx.get("device_name")
        device_index = ctx.get("device_index")
        route_id_seen_by_middleware = ctx.get("route_id_seen_by_middleware")
        route_id = ctx.param("id")
        missing = ctx.get("missing")
        if isinstance(device_name, str) and isinstance(device_index, int) and isinstance(route_id_seen_by_middleware, str) and route_id != "" and missing is None:
            respond(200, {"Content-Type": "text/plain"}, "{device_name}:{device_index}:{route_id_seen_by_middleware}:{route_id}")
            return
        respond(500, {"Content-Type": "text/plain"}, "missing")

    def install(g: http_router.RouteGroup):
        g.use(inject_values)
        g.get("/ctx/{{id}}", handler)

    r.route("/api", install)

    try:
        _serve_and_assert(t, r, _request("GET", "/api/ctx/42"), 200, "edge-1:7:42:42")
    except Exception as e:
        t.failure(e)


actor _test_not_found_on_method_mismatch(t: testing.EnvT):
    r = http_router.Router()
    r.get("/api/ping", _ok_handler)
    r.post("/api/ping", _ok_handler)

    def after_wrong_method():
        _serve_and_assert(t, r, _request("GET", "/does-not-exist"), 404, "")

    try:
        _serve_and_assert(t, r, _request("PATCH", "/api/ping"), 404, "", after_wrong_method)
    except Exception as e:
        t.failure(e)


actor _test_route_groups_join_prefixes(t: testing.EnvT):
    r = http_router.Router()

    def build_v1(g: http_router.RouteGroup):
        g.get("/info", _ok_handler)

    def build_api(g: http_router.RouteGroup):
        g.route("/v1", build_v1)

    r.route("/api", build_api)

    def after_hit():
        _serve_and_assert(t, r, _request("GET", "/info"), 404, "")

    try:
        _serve_and_assert(t, r, _request("GET", "/api/v1/info"), 200, "ok", after_hit)
    except Exception as e:
        t.failure(e)


actor _test_route_bundle_installs_on_root_and_nested_prefixes(t: testing.EnvT):
    r = http_router.Router()

    def install(bundle: http_router.RouteGroup):
        bundle.get("/ping", _ok_handler)

    r.route("/", install)
    r.route("/api", install)

    def after_root():
        _serve_and_assert(t, r, _request("GET", "/api/ping"), 200, "ok")

    try:
        _serve_and_assert(t, r, _request("GET", "/ping"), 200, "ok", after_root)
    except Exception as e:
        t.failure(e)


actor _test_multiple_bundles_can_share_root_prefix(t: testing.EnvT):
    r = http_router.Router()

    def install_health(g: http_router.RouteGroup):
        g.get("/health", _ok_handler)

    def install_metrics(g: http_router.RouteGroup):
        g.get("/metrics", _ok_handler)

    r.route("/", install_health)
    r.route("/", install_metrics)

    def after_health():
        _serve_and_assert(t, r, _request("GET", "/metrics"), 200, "ok")

    try:
        _serve_and_assert(t, r, _request("GET", "/health"), 200, "ok", after_health)
    except Exception as e:
        t.failure(e)


actor _test_scoped_middleware_applies_only_within_installed_bundle(t: testing.EnvT):
    r = http_router.Router()
    r.use(_suffix_middleware(":global"))
    r.get("/root", _ok_handler)

    def install_api(g: http_router.RouteGroup):
        g.use(_suffix_middleware(":api"))
        g.get("/ping", _ok_handler)

    r.route("/api", install_api)

    def after_root():
        _serve_and_assert(t, r, _request("GET", "/api/ping"), 200, "ok:api:global")

    try:
        _serve_and_assert(t, r, _request("GET", "/root"), 200, "ok:global", after_root)
    except Exception as e:
        t.failure(e)


actor _test_route_overlap_is_rejected(t: testing.EnvT):
    r = http_router.Router()

    try:
        r.get("/items/{{id}}", _ok_handler)

        raised = 0
        try:
            r.get("/items/{{slug}}", _ok_handler)
        except ValueError:
            raised = 1

        testing.assertEqual(raised, 1)
        _serve_and_assert(t, r, _request("GET", "/items/abc"), 200, "ok")
    except Exception as e:
        t.failure(e)


actor _test_custom_not_found_handler(t: testing.EnvT):
    r = http_router.Router()

    def custom_not_found(ctx: http_router.Context, respond: proc(int, dict[str, str], str) -> None):
        respond(404, {"Content-Type": "text/plain"}, "missing:{ctx.path}")

    r.not_found(custom_not_found)

    try:
        _serve_and_assert(t, r, _request("GET", "/missing"), 404, "missing:/missing")
    except Exception as e:
        t.failure(e)


actor _test_access_log_middleware(t: testing.EnvT):
    var r = http_router.Router()
    log = logging.Logger(t.log_handler)
    r.use(http_router.access_log_middleware(log))

    def logged_handler(ctx: http_router.Context, respond: proc(int, dict[str, str], str) -> None):
        after 0.1: respond(201, {"Content-Type": "text/plain"}, "logged")

    r.get("/access-log", logged_handler)

    try:
        _serve_and_assert(t, r, _request("GET", "/access-log"), 201, "logged")
    except Exception as e:
        t.failure(e)


actor _test_recoverer_middleware(t: testing.EnvT):
    r = http_router.Router()
    r.use(http_router.recoverer_middleware())

    def boom_handler(ctx, respond):
        raise ValueError("boom")

    r.get("/boom", boom_handler)

    def after_boom():
        _serve_and_assert(t, r, _request("GET", "/bad\\path"), 400, "")

    try:
        _serve_and_assert(t, r, _request("GET", "/boom"), 500, "Internal server error", after_boom)
    except Exception as e:
        t.failure(e)
